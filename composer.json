{
    "name": "justbetter/laravel-akeneo-products",
    "description": "Easily export products to Akeneo from your ERP",
    "type": "package",
    "license": "MIT",
    "homepage": "https://github.com/justbetter/laravel-akeneo-products",
    "authors": [
        {
            "name": "Ramon Rietdijk",
            "email": "ramon@justbetter.nl",
            "role": "Developer"
        },
        {
            "name": "Vincent Boon",
            "email": "vincent@justbetter.nl",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "justbetter/laravel-akeneo-client": "^1.1",
        "justbetter/laravel-error-logger": "^2.3",
        "laravel/framework": "13.*",
        "spatie/laravel-activitylog": "^4.7"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^10.11|^11.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpunit/phpunit": "^13.0",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "JustBetter\\AkeneoProducts\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JustBetter\\AkeneoProducts\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan --memory-limit=256M",
        "style": "pint --test",
        "fix-style": "pint",
        "coverage": "XDEBUG_MODE=coverage php -d memory_limit=2G vendor/bin/phpunit --coverage-text --only-summary-for-coverage-text | grep -c \"100.00%\" | grep -q \"^3$\" && exit 0 || exit 1",
        "quality": [
            "@style",
            "@analyse",
            "@test",
            "@coverage",
            "@rector"
        ],
        "rector": "rector process --dry-run"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JustBetter\\AkeneoProducts\\ServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
